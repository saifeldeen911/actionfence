{
  "name": "actionfence",
  "version": "0.2.1",
  "description": "Server-side policy middleware for MCP servers and Node APIs with spend limits, approvals, schema drift checks, and signed receipts",
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "actionfence": "dist/cli.js"
  },
  "files": [
    "dist",
    "schemas",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src/ tests/",
    "format": "prettier --write .",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test && npm run build"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "better-sqlite3": "^12.9.0",
    "chalk": "^5.4.1",
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "eslint": "^9.26.0",
    "pg": "^8.20.0",
    "prettier": "^3.5.3",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.1",
    "vitest": "^3.1.3"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": ">=1.0.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@modelcontextprotocol/sdk": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "keywords": [
    "ai",
    "agent",
    "mcp",
    "mcp server",
    "mcp-server",
    "agent middleware",
    "tool calling",
    "express middleware",
    "langgraph",
    "langchain",
    "firewall",
    "action-firewall",
    "ai-security",
    "agent-middleware",
    "tool-calling",
    "actionfence",
    "policy",
    "security",
    "middleware",
    "express-middleware",
    "receipts",
    "spend-caps",
    "human-approval",
    "schema-drift",
    "simulation"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/saifeldeen911/actionfence.git"
  },
  "author": "Saifeldeen",
  "homepage": "https://actionfence.dev",
  "bugs": {
    "url": "https://github.com/saifeldeen911/actionfence/issues"
  }
}
