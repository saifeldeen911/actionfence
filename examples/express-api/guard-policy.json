{
  "$schema": "https://raw.githubusercontent.com/saifeldeen911/actionfence/main/schemas/guard-policy.schema.json",
  "service": "BookFlight.com API",
  "version": "1.0",
  "default_rule": "deny",
  "actions": {
    "GET /flights": {
      "allowed": true,
      "identity": "any"
    },
    "POST /bookings": {
      "allowed": true,
      "identity": "verified",
      "max_spend": 1000,
      "currency": "USD",
      "requires_human_approval": true
    },
    "GET /bookings/:id": {
      "allowed": true,
      "identity": "token"
    },
    "DELETE /bookings/:id": {
      "allowed": false
    }
  },
  "rate_limits": {
    "requests_per_minute": 60,
    "transactions_per_day": 10
  },
  "spend_limits": {
    "session_max": 2000,
    "daily_max": 5000,
    "currency": "USD"
  },
  "regulations": [
    "EU_AI_Act_Art50"
  ]
}
