{
  "$schema": "https://agentguard.dev/schema/v1/guard-policy.schema.json",
  "service": "BookFlight.com API",
  "version": "1.0",
  "default_rule": "deny",
  "actions": {
    "GET /flights": {
      "allowed": true,
      "identity": "any"
    },
    "POST /bookings": {
      "allowed": true,
      "identity": "verified",
      "max_spend": 1000,
      "requires_human_approval": true
    },
    "GET /bookings/:id": {
      "allowed": true,
      "identity": "token"
    },
    "DELETE /bookings/:id": {
      "allowed": false
    }
  },
  "rate_limits": {
    "requests_per_minute": 60,
    "transactions_per_day": 10
  },
  "regulations": ["EU_AI_Act_Art50"]
}
